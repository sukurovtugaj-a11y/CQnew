using System.Collections;
using System.Collections.Generic;
using UnityEngine;

public class PlayerMenuScript : MonoBehaviour
{
    public GameObject MenuPanel;

    public PlayerInteraction playerInteraction;

    private bool isPaused = false;

    private GameObject currentOtherPanel;

    public bool IsAnyMenuOpen => isPaused || currentOtherPanel != null;

    void Update()
    {
        if (Input.GetKeyDown(KeyCode.Escape))
        {
            // Если открыта другая панель — закрываем её
            if (currentOtherPanel != null)
            {
                CloseOtherPanel();
            }
            else
            {
                // Иначе работаем со старой паузой
                TogglePause();
            }
        }

        //if (Input.GetKeyDown(KeyCode.Escape))
        //{
        //    TogglePause();
        //}
    }

    void TogglePause()
    {
        isPaused = !isPaused;
        MenuPanel.SetActive(isPaused);

        if (isPaused)
        {
            Time.timeScale = 0;
            Cursor.visible = true;
            if (currentOtherPanel != null)
                CloseOtherPanel();
        }
        else
        {
            Time.timeScale = 1;
            Cursor.visible = false;
        }

        if (playerInteraction != null)
            playerInteraction.RefreshInteractIcon();
    }

    public void OpenPanel(GameObject panel)
    {
        if (panel == null) return;
        if (panel == MenuPanel) // если вдруг передали MenuPanel, используем TogglePause
        {
            if (!isPaused) TogglePause();
            return;
        }

        // Если уже открыта другая панель, закрываем её
        if (currentOtherPanel != null)
            CloseOtherPanel();

        // Если открыто меню паузы, закрываем его
        if (isPaused)
            ResumeGame(); // Это сбросит isPaused и timeScale

        // Открываем новую панель
        currentOtherPanel = panel;
        currentOtherPanel.SetActive(true);
        Time.timeScale = 0f;
        Cursor.visible = true;

        if (playerInteraction != null)
            playerInteraction.RefreshInteractIcon();
    }

    // Закрывает только 'другую' панель
    private void CloseOtherPanel()
    {
        if (currentOtherPanel != null)
        {
            currentOtherPanel.SetActive(false);
            currentOtherPanel = null;
            Time.timeScale = 1f;
            Cursor.visible = false;

            if (playerInteraction != null)
                playerInteraction.RefreshInteractIcon();
        }
    }

    public void CloseCurrentPanel()
    {
        if (currentOtherPanel != null)
            CloseOtherPanel();
        else if (isPaused)
            ResumeGame();
    }

    public void ResumeGame()
    {
        isPaused = false;
        MenuPanel.SetActive(false);
        Time.timeScale = 1;
        Cursor.visible = false;

        if (playerInteraction != null)
            playerInteraction.RefreshInteractIcon();
    }
}