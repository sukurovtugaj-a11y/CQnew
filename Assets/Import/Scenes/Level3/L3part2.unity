  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.017004728, g: 1, b: 0, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: d694593fd25507641a05177c4f1a6087, type: 3}
    m_FontSize: 15
    m_FontStyle: 0
    m_BestFit: 1
    m_MinSize: 15
    m_MaxSize: 300
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "if = \u0435\u0441\u043B\u0438. \u041F\u0440\u043E\u0432\u0435\u0440\u044F\u0435\u0442,
    \u0438\u0441\u0442\u0438\u043D\u043D\u043E \u043B\u0438 \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u0435.\n\nelse
    = \u0438\u043D\u0430\u0447\u0435. \u041D\u0435 \u0442\u0440\u0435\u0431\u0443\u0435\u0442
    \u0443\u0441\u043B\u043E\u0432\u0438\u0439 \u0432 \u0441\u043A\u043E\u0431\u043A\u0430\u0445.
    \u0412\u044B\u043F\u043E\u043B\u043D\u044F\u0435\u0442\u0441\u044F \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u043E\u0433\u0434\u0430, \u043A\u043E\u0433\u0434\u0430
    \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0430 if \u0432\u0435\u0440\u043D\u0443\u043B\u0430
    \u043B\u043E\u0436\u044C. \u042D\u0442\u043E \"\u043F\u043B\u0430\u043D \u0411\"
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0435 \u0437\u0430\u0434\u0430\u0451\u0442 \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u0432,
    \u0430 \u043F\u0440\u043E\u0441\u0442\u043E \u0438\u0441\u043F\u043E\u043B\u043D\u044F\u0435\u0442\u0441\u044F."
