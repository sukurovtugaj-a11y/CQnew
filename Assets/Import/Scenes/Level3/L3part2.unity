  m_Text: "\u0426\u0438\u043A\u043B for - \u041F\u043E\u0432\u0442\u043E\u0440\u044F\u0435\u0442
    \u0431\u043B\u043E\u043A, \u043F\u043E\u043A\u0430 \u0443\u0441\u043B\u043E\u0432\u0438\u0435
    \u0438\u0441\u0442\u0438\u043D\u043D\u043E. \u0411\u043B\u043E\u043A \u0434\u043E\u043B\u0436\u0435\u043D
    \u0431\u044B\u0442\u044C \u0432 \u043A\u043E\u0434\u0435, \u0447\u0442\u043E\u0431\u044B
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440 \u0442\u043E\u0447\u043D\u043E
    \u0437\u043D\u0430\u043B, \u0433\u0434\u0435 \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0430
    \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F \u0438 \u0437\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F.\n\n\u041A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044F
    \u0446\u0438\u043A\u043B\u0430:\nfor (\u0438\u043D\u0438\u0446\u0438\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u044F;
    \u0443\u0441\u043B\u043E\u0432\u0438\u0435; \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0435)
    { } "
