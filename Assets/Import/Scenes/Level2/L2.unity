    m_Font: {fileID: 12800000, guid: d694593fd25507641a05177c4f1a6087, type: 3}
    m_FontSize: 15
    m_FontStyle: 0
    m_BestFit: 1
    m_MinSize: 15
    m_MaxSize: 300
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "if = \u0435\u0441\u043B\u0438. \u041F\u0440\u043E\u0432\u0435\u0440\u044F\u0435\u0442,
    \u0438\u0441\u0442\u0438\u043D\u043D\u043E \u043B\u0438 \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u0435.
    \u0412 \u043A\u043E\u0434\u0435 \u0443\u0441\u043B\u043E\u0432\u0438\u0435 \u0432\u0441\u0435\u0433\u0434\u0430
    \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F \u0432 \u043A\u0440\u0443\u0433\u043B\u044B\u0435
    \u0441\u043A\u043E\u0431\u043A\u0438 ( ), \u0447\u0442\u043E\u0431\u044B \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440
    \u0442\u043E\u0447\u043D\u043E \u0437\u043D\u0430\u043B, \u0433\u0434\u0435 \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0430
    \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442\u0441\u044F \u0438 \u0437\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F.\n\n\u0411\u0435\u0437
    \u0441\u043A\u043E\u0431\u043E\u043A \u0441\u0438\u0441\u0442\u0435\u043C\u0430
    \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0442, \u0447\u0442\u043E
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0441\u044F \u043A if, \u0430 \u0447\u0442\u043E
    \u0438\u0434\u0451\u0442 \u0434\u0430\u043B\u044C\u0448\u0435."
