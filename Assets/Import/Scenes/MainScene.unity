  m_Text: "\u041E\u043B\u0438\u0446\u0435\u0442\u0432\u043E\u0440\u044F\u0435\u0442
    \u0446\u0435\u043B\u044B\u0435 \u0447\u0438\u0441\u043B\u0430. \u041C\u0430\u0441\u0441\u0438\u0432\u043D\u044B\u0439
    \u043A\u043E\u0440\u043F\u0443\u0441 \u043D\u0430 \u043C\u0430\u043B\u044B\u0445
    \u043A\u043E\u043B\u0451\u0441\u0430\u0445, \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u044B\u0439.
    \u041D\u0430 \u0434\u0438\u0441\u043F\u043B\u0435\u0435 \u0441\u0432\u0435\u0442\u044F\u0442\u0441\u044F
    \u0447\u0438\u0441\u043B\u0430 (18, 5, 10, 15, 195100), \u043A\u0430\u0436\u0434\u043E\u0435
    \u0437\u0430\u043F\u0443\u0441\u043A\u0430\u0435\u0442 \u0441\u0432\u043E\u044E
    \u0430\u0442\u0430\u043A\u0443 (\u0440\u0430\u043A\u0435\u0442\u044B, \u043B\u0430\u0437\u0435\u0440\u044B,
    \u0432\u044B\u0434\u0432\u0438\u0436\u043D\u0430\u044F \u043C\u0430\u0445\u0438\u043D\u0430)."
