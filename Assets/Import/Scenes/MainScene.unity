  m_Text: "\u0418\u0433\u043D\u043E\u0440\u0438\u0440\u0443\u0439\u0442\u0435 \u0435\u0433\u043E
    \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0431\u043E\u044F. \u0421\u043D\u0430\u0447\u0430\u043B\u0430
    \u0437\u0430\u0447\u0438\u0441\u0442\u0438\u0442\u0435 \u0432\u0441\u0435\u0445
    \xAB\u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u043E\u0432\xBB. \u041A\u0430\u043A
    \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u043D\u0438 \u0438\u0441\u0447\u0435\u0437\u043D\u0443\u0442,
    \u0421\u0442\u0430\u0440\u0435\u0446 \u043F\u043E\u0442\u0435\u0440\u044F\u0435\u0442
    \u043D\u0435\u0443\u044F\u0437\u0432\u0438\u043C\u043E\u0441\u0442\u044C \u0438
    \u0441\u0442\u0430\u043D\u0435\u0442 \u043B\u0451\u0433\u043A\u043E\u0439 \u0446\u0435\u043B\u044C\u044E."
