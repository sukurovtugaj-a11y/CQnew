    \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A \u0443\u044F\u0437\u0432\u0438\u043C
    \u0438 \u0432 \u0446\u0435\u043B\u043E\u043C \u0431\u0435\u0437\u043E\u0431\u0438\u0434\u0435\u043D,
    \u043D\u043E \u0441\u0442\u0430\u0432 True \u043E\u043D 15 \u0441\u0435\u043A\u0443\u043D\u0434
    \u0431\u0443\u0434\u0435\u0442 \u0433\u043D\u0430\u0442\u044C\u0441\u044F \u0437\u0430
    \u0432\u0430\u043C\u0438, \u043D\u0430\u043D\u043E\u0441\u044F \u043D\u0430\u043D\u0435\u0441\u0442\u0438
    \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E \u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u0443\u0440\u043E\u043D, \u043E\u0431\u0440\u0435\u0442\u044F \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C \u043D\u0443\u044F\u0437\u0432\u0438\u043C\u043E\u0441\u0442\u044C."
